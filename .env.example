# This file shows all required environment variables for the eSign Platform
# Copy this to .env.local and fill in your actual values
# NEVER commit .env.local to git - it contains secret keys

# Environment
NODE_ENV=development
PORT=4000
API_URL=http://localhost:4000

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/esign_db?sslmode=disable"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT / Authentication
JWT_SECRET=your-secret-key-minimum-64-characters-change-in-production
JWT_PRIVATE_KEY_PATH=./keys/jwt_private.pem
JWT_PUBLIC_KEY_PATH=./keys/jwt_public.pem
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_EXPIRES_IN=30d

# AWS S3 (for file storage in production)
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-bucket-name
AWS_KMS_KEY_ID=your-kms-key-id

# Encryption
AES_ENCRYPTION_KEY=your-aes-encryption-key-32-chars
AES_IV_LENGTH=16

# X402 Payment Configuration
X402_NETWORK=base-sepolia
X402_FACILITATOR_URL=https://facilitator.yourdomain.com
X402_WALLET_ADDRESS=0xa2B39121fb512817d0556Fe795574D314C355f17
X402_CHAIN_ID=84532
X402_PRICE_PER_SIGN=0.0001

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=noreply@yourdomain.com

# TOTP/MFA Configuration
TOTP_APP_NAME=eSign
TOTP_ISSUER=eSign

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Webhook Security
WEBHOOK_SECRET=your-webhook-secret-key
