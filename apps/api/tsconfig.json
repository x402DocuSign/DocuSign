{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "moduleResolution": "node",
    "baseUrl": ".",
    "paths": {
      "@esign/utils": ["../../packages/utils/dist"],
      "@esign/utils/*": ["../../packages/utils/dist/*"],
      "@esign/db": ["../../packages/db/dist"],
      "@esign/db/*": ["../../packages/db/dist/*"],
      "@esign/crypto": ["../../packages/crypto/dist"],
      "@esign/crypto/*": ["../../packages/crypto/dist/*"],
      "@esign/payments": ["../../packages/payments/dist"],
      "@esign/payments/*": ["../../packages/payments/dist/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}