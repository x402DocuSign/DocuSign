# Ignore unnecessary files for Vercel deployment

# Documentation
*.md
docs/

# Development files
.turbo/
.git/
.gitignore
.npmrc

# Testing
test-*.js
test-*.mjs
coverage/

# Debug and logs
*.log
api-debug.txt
api-output.txt
apps/api/logs/

# PM2 config (used for traditional deployment, not Vercel)
ecosystem.config.js

# Local development
.env.local
.env.development.local
apps/api/.env.local
apps/web/.env.local
apps/docs/.env.local

# Turbo cache
.turbo/
.next/out/

# Build artifacts (these are generated on Vercel)
dist/
out/
build/

# dependencies (installed fresh on Vercel)
node_modules/
pnpm-lock.yaml

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
