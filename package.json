{
  "name": "esign-platform",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "start": "turbo start",
    "lint": "turbo lint",
    "db:migrate": "pnpm --filter @esign/db migrate",
    "db:generate": "pnpm --filter @esign/db generate",
    "db:studio": "pnpm --filter @esign/db studio"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.0",
    "@types/node": "^20.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/speakeasy": "^2.0.10",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "8.57.2",
    "@typescript-eslint/parser": "8.57.2",
    "eslint": "8.57.1",
    "eslint-plugin-react": "7.34.0",
    "turbo": "^2.9.0",
    "typescript": "^5.4.0"
  },
  "packageManager": "pnpm@9.0.0",
  "dependencies": {
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/client": "7.6.0",
    "@types/next-auth": "^3.15.0",
    "bcryptjs": "^2.4.3",
    "express": "^4.18",
    "next-auth": "^4.24.13",
    "prisma": "7.6.0",
    "speakeasy": "^2.0.0"
  },
  "pnpm": {
    "overrides": {
      "glob": ">=10.5.0",
      "next": ">=15.0.8"
    }
  }
}