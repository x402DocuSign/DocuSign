package-manager=pnpm@9

# Registry settings with fallback
registry=https://registry.npmjs.org/
registry=https://registry.yarnpkg.com/

# Alternative registry fallback
@yarnpkg:registry=https://registry.yarnpkg.com/

# Network resilience
network-timeout=120000
fetch-timeout=120000
fetch-retry-mintimeout=30000
fetch-retry-maxtimeout=180000
fetch-retries=10
strict-ssl=false

# pnpm specific settings
shamefully-hoist=true
hoist-pattern=*

# Disable audit for faster installs
ignore-scripts=false
progress=true